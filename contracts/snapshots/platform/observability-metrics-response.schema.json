{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"metrics": {
			"additionalProperties": false,
			"properties": {
				"availabilityTarget": {
					"type": "number"
				},
				"errorRate": {
					"type": "number"
				},
				"generatedAt": {
					"minLength": 1,
					"type": "string"
				},
				"latencyTargetMs": {
					"type": "number"
				},
				"p95Ms": {
					"type": "number"
				},
				"routes": {
					"items": {
						"additionalProperties": false,
						"properties": {
							"errorCount": {
								"maximum": 9007199254740991,
								"minimum": 0,
								"type": "integer"
							},
							"p50Ms": {
								"type": "number"
							},
							"p95Ms": {
								"type": "number"
							},
							"p99Ms": {
								"type": "number"
							},
							"requestCount": {
								"maximum": 9007199254740991,
								"minimum": 0,
								"type": "integer"
							},
							"route": {
								"minLength": 1,
								"type": "string"
							}
						},
						"required": [
							"route",
							"requestCount",
							"errorCount",
							"p50Ms",
							"p95Ms",
							"p99Ms"
						],
						"type": "object"
					},
					"type": "array"
				},
				"sloBreached": {
					"type": "boolean"
				},
				"totalRequests": {
					"maximum": 9007199254740991,
					"minimum": 0,
					"type": "integer"
				},
				"windowMinutes": {
					"exclusiveMinimum": 0,
					"maximum": 9007199254740991,
					"type": "integer"
				}
			},
			"required": [
				"generatedAt",
				"windowMinutes",
				"totalRequests",
				"errorRate",
				"p95Ms",
				"availabilityTarget",
				"latencyTargetMs",
				"sloBreached",
				"routes"
			],
			"type": "object"
		}
	},
	"required": ["metrics"],
	"type": "object"
}
