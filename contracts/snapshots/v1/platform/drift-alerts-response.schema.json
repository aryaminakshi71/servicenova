{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"alerts": {
			"items": {
				"additionalProperties": false,
				"properties": {
					"acknowledged": {
						"type": "boolean"
					},
					"acknowledgement": {
						"anyOf": [
							{
								"additionalProperties": false,
								"properties": {
									"acknowledgedAt": {
										"minLength": 1,
										"type": "string"
									},
									"acknowledgedBy": {
										"minLength": 1,
										"type": "string"
									},
									"alertId": {
										"minLength": 1,
										"type": "string"
									},
									"note": {
										"anyOf": [
											{
												"type": "string"
											},
											{
												"type": "null"
											}
										]
									},
									"owner": {
										"minLength": 1,
										"type": "string"
									},
									"slaDueAt": {
										"minLength": 1,
										"type": "string"
									}
								},
								"required": [
									"alertId",
									"owner",
									"acknowledgedBy",
									"acknowledgedAt",
									"slaDueAt",
									"note"
								],
								"type": "object"
							},
							{
								"type": "null"
							}
						]
					},
					"id": {
						"minLength": 1,
						"type": "string"
					},
					"message": {
						"minLength": 1,
						"type": "string"
					},
					"metrics": {
						"additionalProperties": false,
						"properties": {
							"meanAbsoluteErrorMinutes": {
								"type": "number"
							},
							"within15MinutesRate": {
								"type": "number"
							}
						},
						"required": ["meanAbsoluteErrorMinutes", "within15MinutesRate"],
						"type": "object"
					},
					"sampleCount": {
						"maximum": 9007199254740991,
						"minimum": 0,
						"type": "integer"
					},
					"scope": {
						"enum": ["overall", "priority", "skill"],
						"type": "string"
					},
					"segment": {
						"minLength": 1,
						"type": "string"
					},
					"severity": {
						"enum": ["low", "medium", "high"],
						"type": "string"
					},
					"triggeredAt": {
						"minLength": 1,
						"type": "string"
					}
				},
				"required": [
					"id",
					"severity",
					"scope",
					"segment",
					"sampleCount",
					"message",
					"triggeredAt",
					"metrics",
					"acknowledged",
					"acknowledgement"
				],
				"type": "object"
			},
			"type": "array"
		}
	},
	"required": ["alerts"],
	"type": "object"
}
