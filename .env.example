# App identity
APP_NAME=servicenova-ai
PORT=3403
NODE_ENV=development

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/servicenova-ai
FIELD_OPS_PERSISTENCE=memory

# AI
OPENAI_API_KEY=

# Auth
BETTER_AUTH_SECRET=change-me

# Integrations
CRM_PROVIDER=mock
INVOICING_PROVIDER=mock
CRM_BASE_URL=
CRM_API_KEY=
INVOICING_BASE_URL=
INVOICING_API_KEY=
# HTTP integration reliability policy
INTEGRATION_HTTP_RETRIES=2
INTEGRATION_HTTP_RETRY_BASE_MS=20
INTEGRATION_HTTP_TIMEOUT_MS=2500
INTEGRATION_HTTP_CIRCUIT_FAILURE_THRESHOLD=3
INTEGRATION_HTTP_CIRCUIT_COOLDOWN_MS=30000

# Security
# Demo auth token format: Authorization: Bearer <role:userId>
# Example: Bearer manager:web-dashboard
AUTH_REQUIRED=true
# Query-param auth fallback used by browser EventSource when no Authorization header can be set.
# Defaults to true outside production if unset.
AUTH_ALLOW_QUERY_FALLBACK=true
# Request rate limiting (per user + route)
# Defaults to enabled outside test runtime.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MUTATION_LIMIT=120
RATE_LIMIT_INTEGRATION_LIMIT=60
RATE_LIMIT_ADMIN_MUTATION_LIMIT=300
RATE_LIMIT_ADMIN_INTEGRATION_LIMIT=180
# Optional comma-separated bypass lists.
# Examples:
# RATE_LIMIT_BYPASS_ROLES=admin
# RATE_LIMIT_BYPASS_SUBJECTS=manager:web-dashboard,admin:ops-admin
RATE_LIMIT_BYPASS_ROLES=
RATE_LIMIT_BYPASS_SUBJECTS=

# Feature flags
FEATURE_REALTIME_BOARD=true
FEATURE_CRM_INTEGRATION=true
FEATURE_INVOICING_INTEGRATION=true
FEATURE_PREDICTIVE_MAINTENANCE=true
FEATURE_IDEMPOTENCY=true
