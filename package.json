{
  "name": "servicenova-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run src/features src/server/rate-limit.test.ts src/server/persistence/rate-limit-repository.test.ts src/server/db/persistence.test.ts",
    "test:api": "vitest run src/server/routes/*.integration.test.ts",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "load:smoke": "bash scripts/load-smoke.sh",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit generate && (git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git diff --exit-code -- drizzle/schema.ts drizzle/migrations || echo 'Skipping git diff check (not a git worktree)')",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
