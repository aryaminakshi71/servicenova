{
  "name": "servicenova-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:no-cloudflare": "SKIP_CLOUDFLARE=true vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run src/features src/server/background-jobs.test.ts src/server/rate-limit.test.ts src/server/persistence/rate-limit-repository.test.ts src/server/db/persistence.test.ts",
    "test:api": "vitest run src/server/routes/*.integration.test.ts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:chaos:resilience": "vitest run src/features/integrations/providers/http.chaos.test.ts src/server/routes/chaos.resilience.integration.test.ts",
    "test:security:fuzz": "vitest run src/server/routes/security.fuzz.integration.test.ts",
    "contract:snapshots:check": "bun run scripts/contracts/check-dispatch-contract-snapshots.ts",
    "contract:snapshots:update": "bun run scripts/contracts/check-dispatch-contract-snapshots.ts --write",
    "contract:snapshots:update:v1": "bun run scripts/contracts/check-dispatch-contract-snapshots.ts --write --write-v1",
    "lint:ratchet:check": "node scripts/ci/check-biome-ratchet.mjs",
    "lint:ratchet:update": "node scripts/ci/check-biome-ratchet.mjs --write-baseline",
    "ci:timing:check": "node scripts/ci/check-timing-budgets.mjs",
    "perf:gate": "bun run scripts/ci/performance-gate.ts",
    "canary:run": "bun run scripts/ci/run-canary-flow.ts",
    "sbom:generate": "node scripts/ci/generate-sbom.mjs",
    "provenance:generate": "node scripts/ci/generate-provenance.mjs",
    "supply-chain:sign": "bash scripts/ci/sign-supply-chain.sh",
    "supply-chain:sign:cosign": "bash scripts/ci/sign-supply-chain-cosign.sh",
    "security:dep-policy": "node scripts/ci/enforce-dependency-policy.mjs",
    "db:migration:rehearsal": "bash scripts/ci/rehearse-migrations.sh",
    "branch-protection:check": "node scripts/ci/verify-branch-protection-policy.mjs",
    "branch-protection:apply": "node scripts/ci/apply-branch-protection.mjs",
    "protected-branch:guard": "node scripts/ci/verify-protected-branch-governance.mjs",
    "test:watch": "vitest",
    "load:smoke": "bash scripts/load-smoke.sh",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit generate && (git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git diff --exit-code -- drizzle/schema.ts drizzle/migrations || echo 'Skipping git diff check (not a git worktree)')",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "biome check .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "clean": "rm -rf node_modules .turbo",
    "test:all": "bun run test && bun run test:e2e",
    "security:audit": "bun audit",
    "security:scan": "bunx snyk test",
    "health": "node scripts/platform-healthcheck.mjs",
    "db:seed": "node scripts/platform-db-seed.mjs",
    "start": "bun run dev",
    "test:integration": "vitest run src/integration --passWithNoTests"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@neondatabase/serverless": "^0.10.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.1.0",
    "@orpc/client": "^1.13.4",
    "@orpc/json-schema": "^1.13.4",
    "@orpc/openapi": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "@orpc/tanstack-query": "^1.13.4",
    "@orpc/zod": "^1.13.4",
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-aspect-ratio": "1.1.1",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-hover-card": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-navigation-menu": "1.2.3",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "@sentry/cloudflare": "^10.36.0",
    "@sentry/react": "^8.55.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.90.20",
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-router-devtools": "^1.158.1",
    "@tanstack/react-router-ssr-query": "^1.158.1",
    "@tanstack/react-start": "^1.158.3",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.36.1",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "date-fns": "4.1.0",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "8.5.1",
    "hono": "^4.11.7",
    "input-otp": "1.4.1",
    "lucide-react": "^0.454.0",
    "next-themes": "^0.4.6",
    "openai": "^6.21.0",
    "postgres": "^3.4.8",
    "posthog-js": "^1.170.0",
    "posthog-node": "^4.15.0",
    "react": "^19.2.0",
    "react-day-picker": "9.8.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.60.0",
    "react-hot-toast": "^2.4.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@cloudflare/vite-plugin": "^1.22.1",
    "@cloudflare/workers-types": "^4.20260214.0",
    "@playwright/test": "^1.50.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/devtools-vite": "^0.4.1",
    "@tanstack/router-plugin": "^1.158.1",
    "@testing-library/dom": "^9.3.3",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "1.6.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.29.0",
    "jsdom": "^23.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^1.6.0",
    "wrangler": "^4.63.0"
  },
  "packageManager": "bun@1.3.5"
}
