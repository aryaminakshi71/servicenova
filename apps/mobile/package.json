{
  "name": "servicenova-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "npx eas build --platform android --profile android-device",
    "build:ios": "npx eas build --platform ios --profile development",
    "build:ios:simulator": "npx eas build --platform ios --profile ios-simulator",
    "build:preview": "npx eas build --platform all --profile preview",
    "build:production": "npx eas build --platform all --profile production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test:integration": "vitest run src/integration --passWithNoTests",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-notifications": "~0.32.16",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2",
    "vitest": "^2.1.8"
  },
  "private": true
}
