{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
		"experimentalScannerIgnores": [
			"coverage/**",
			"dist/**",
			"node_modules/**",
			".turbo/**"
		]
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	}
}
